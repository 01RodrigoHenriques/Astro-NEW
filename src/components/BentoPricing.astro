---
interface PricingCardProps {
  titleBadge: string
  priceLabel: string
  priceSuffix?: string
  features: string[]
  cta?: string
  className?: string
}

const pricingCards: PricingCardProps[] = [
  {
    titleBadge: "FREE",
    priceLabel: "$0",
    features: ["$5 of included monthly credits", "Deploy apps to Vercel", "Edit visually with Design Mode", "Sync with GitHub"],
    className: "lg:col-span-3",
    cta: "Get Started",
  },
  {
    titleBadge: "TEAM",
    priceLabel: "$30",
    priceSuffix: "/user/month",
    features: ["$30 of included monthly credits per user", "Centralized billing on vercel.com", "Share chats and collaborate with your team"],
    className: "lg:col-span-4",
  },
  {
    titleBadge: "BUSINESS",
    priceLabel: "$100",
    priceSuffix: "/user/month",
    features: ["$30 of included monthly credits per user", "Training opt-out by default", "Access to v0 API"],
    className: "lg:col-span-4",
  },
  {
    titleBadge: "ENTERPRISE",
    priceLabel: "Custom",
    priceSuffix: "",
    features: ["Training opt-out by default", "SAML SSO", "Priority access for better performance", "Dedicated customer support"],
    className: "lg:col-span-8",
    cta: "Contact Sales",
  },
]

const checkIcon = `<svg class="w-[1.05rem] h-[1.05rem] text-white flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>`

const sparklesIcon = `<svg class="me-1 size-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg>`

const scrollToContact = `document.getElementById('contact')?.scrollIntoView({behavior:'smooth',block:'nearest'})`
---

<div class="grid grid-cols-1 gap-1.5 md:grid-cols-2 lg:grid-cols-8">
  <!-- Premium Card -->
  <div class="bg-white/5 border-white/10 relative w-full overflow-hidden rounded-md border-2 backdrop-blur-sm lg:col-span-5">
    <div class="absolute inset-0 pointer-events-none">
      <svg class="pointer-events-none absolute inset-0 h-full w-full fill-white/20" aria-hidden="true">
        <defs><pattern id="dots-premium" width="5" height="5" patternUnits="userSpaceOnUse"><circle cx="1" cy="0.5" r="0.5"></circle></pattern></defs>
        <rect width="100%" height="100%" stroke-width="0" fill="url(#dots-premium)"></rect>
      </svg>
    </div>
    <div class="flex items-center gap-3 p-3">
      <span class="inline-flex items-center justify-center rounded-md border border-transparent bg-secondary text-secondary-foreground px-2 py-0.5 text-xs font-medium text-white border-white/20 font-open-sans-custom">PREMIUM</span>
      <span class="hidden lg:inline-flex items-center justify-center rounded-md border bg-white/5 text-white border-white/20 font-open-sans-custom text-xs px-2 py-0.5" set:html={`${sparklesIcon} Popular`} />
      <div class="ml-auto">
        <button onclick={scrollToContact} class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium bg-white text-black hover:bg-gray-100 font-open-sans-custom text-xs h-8 px-3">Subscribe</button>
      </div>
    </div>
    <div class="flex flex-col p-3 lg:flex-row">
      <div class="pb-2 lg:w-[30%]">
        <span class="font-mono text-3xl font-semibold tracking-tight text-white [text-shadow:_0_4px_20px_rgb(0_0_0_/_60%)]">$20</span>
        <span class="text-gray-300 text-xs font-open-sans-custom">/month</span>
      </div>
      <ul class="text-gray-300 grid gap-2 text-xs lg:w-[70%] font-open-sans-custom">
        {["$20 of included monthly credits", "Purchase additional credits outside of your monthly usage", "5x higher attachment size limits", "Import from Figma"].map((f) => (
          <li class="flex items-center gap-2" set:html={`${checkIcon}<span class="leading-relaxed">${f}</span>`} />
        ))}
      </ul>
    </div>
  </div>

  {pricingCards.map((card) => (
    <div class={`bg-white/5 border-white/10 relative overflow-hidden rounded-md border-2 backdrop-blur-sm ${card.className || ""}`}>
      <div class="absolute inset-0 pointer-events-none">
        <svg class="pointer-events-none absolute inset-0 h-full w-full fill-white/20" aria-hidden="true">
          <defs><pattern id={`dots-${card.titleBadge}`} width="5" height="5" patternUnits="userSpaceOnUse"><circle cx="1" cy="0.5" r="0.5"></circle></pattern></defs>
          <rect width="100%" height="100%" stroke-width="0" fill={`url(#dots-${card.titleBadge})`}></rect>
        </svg>
      </div>
      <div class="flex items-center gap-3 p-3">
        <span class="inline-flex items-center justify-center rounded-md border border-transparent bg-secondary text-secondary-foreground px-2 py-0.5 text-xs font-medium text-white border-white/20 font-open-sans-custom">{card.titleBadge}</span>
        <div class="ml-auto">
          <button onclick={scrollToContact} class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground h-8 px-3 bg-white/5 text-white border-white/20 hover:bg-white/10 font-open-sans-custom text-xs">{card.cta || "Subscribe"}</button>
        </div>
      </div>
      <div class="flex items-end gap-2 px-3 py-1">
        <span class="font-mono text-3xl font-semibold tracking-tight text-white [text-shadow:_0_4px_20px_rgb(0_0_0_/_60%)]">{card.priceLabel}</span>
        {card.priceLabel.toLowerCase() !== "free" && <span class="text-gray-300 text-xs font-open-sans-custom">{card.priceSuffix}</span>}
      </div>
      <ul class="text-gray-300 grid gap-2 p-3 text-xs font-open-sans-custom">
        {card.features.map((f) => (
          <li class="flex items-center gap-2" set:html={`${checkIcon}<span>${f}</span>`} />
        ))}
      </ul>
    </div>
  ))}
</div>
