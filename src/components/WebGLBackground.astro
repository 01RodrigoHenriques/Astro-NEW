<canvas id="liquid-canvas" class="liquid-canvas" aria-hidden="true"></canvas>

<script is:inline>
(function(){
  var c = document.getElementById('liquid-canvas');
  if(!c) return;
  var gl = c.getContext('webgl');
  if(!gl) return;

  var vs = gl.createShader(gl.VERTEX_SHADER);
  gl.shaderSource(vs, 'attribute vec2 p;void main(){gl_Position=vec4(p,0,1);}');
  gl.compileShader(vs);

  var fs = gl.createShader(gl.FRAGMENT_SHADER);
  gl.shaderSource(fs, 'precision mediump float;uniform float t;uniform vec2 r;'+function(){/*
vec3 mod289(vec3 x){return x-floor(x/289.)*289.;}
vec2 mod289(vec2 x){return x-floor(x/289.)*289.;}
vec3 perm(vec3 x){return mod289(((x*34.)+1.)*x);}
float snoise(vec2 v){
  const vec4 C=vec4(.21132,.36603,-.57735,.02439);
  vec2 i=floor(v+dot(v,C.yy));
  vec2 x0=v-i+dot(i,C.xx);
  vec2 i1=(x0.x>x0.y)?vec2(1,0):vec2(0,1);
  vec4 x12=x0.xyxy+C.xxzz;x12.xy-=i1;i=mod289(i);
  vec3 p=perm(perm(i.y+vec3(0,i1.y,1))+i.x+vec3(0,i1.x,1));
  vec3 m=max(.5-vec3(dot(x0,x0),dot(x12.xy,x12.xy),dot(x12.zw,x12.zw)),0.);
  m=m*m;m=m*m;
  vec3 x=2.*fract(p*C.www)-1.;
  vec3 h=abs(x)-.5;vec3 ox=floor(x+.5);vec3 a0=x-ox;
  m*=1.79284-.85373*(a0*a0+h*h);
  vec3 g;g.x=a0.x*x0.x+h.x*x0.y;g.yz=a0.yz*x12.xz+h.yz*x12.yw;
  return 130.*dot(m,g);
}
void main(){
  vec2 uv=gl_FragCoord.xy/r;
  float T=t*.4;
  float n1=snoise(uv*3.+vec2(T*.8,T*.4));
  float n2=snoise(uv*5.+vec2(-T*.6,T*.9));
  float n3=snoise(uv*2.+vec2(T*.3,-T*.5));
  float v=n1*.5+n2*.3+n3*.2;
  vec3 c0=vec3(0.02,0.04,0.1);
  vec3 c1=vec3(0.08,0.12,0.25);
  vec3 c2=vec3(0.12,0.18,0.35);
  float s=(v+1.)*.5;
  vec3 c=c0;
  c=mix(c,c1,smoothstep(.2,.6,s));
  c=mix(c,c2,smoothstep(.5,.9,s)*.6);
  float h=snoise(uv*10.+vec2(T*1.5,T));
  c+=vec3(0.05,0.08,0.15)*pow(max(h,0.),4.)*.8;
  float d=1.-length((uv-.5)*1.3);
  c*=smoothstep(0.,.6,d);
  gl_FragColor=vec4(c,1);
}
*/}.toString().slice(14,-3));
  gl.compileShader(fs);

  var pg=gl.createProgram();
  gl.attachShader(pg,vs);gl.attachShader(pg,fs);
  gl.linkProgram(pg);gl.useProgram(pg);

  var b=gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER,b);
  gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),gl.STATIC_DRAW);
  var pos=gl.getAttribLocation(pg,'p');
  gl.enableVertexAttribArray(pos);
  gl.vertexAttribPointer(pos,2,gl.FLOAT,false,0,0);

  var tL=gl.getUniformLocation(pg,'t');
  var rL=gl.getUniformLocation(pg,'r');

  function resize(){
    c.width=window.innerWidth;c.height=window.innerHeight;
    gl.viewport(0,0,c.width,c.height);
  }
  var t0=performance.now();
  function render(){
    gl.uniform1f(tL,(performance.now()-t0)/1000);
    gl.uniform2f(rL,c.width,c.height);
    gl.drawArrays(gl.TRIANGLE_STRIP,0,4);
    requestAnimationFrame(render);
  }
  resize();render();
  window.addEventListener('resize',resize);
})();
</script>