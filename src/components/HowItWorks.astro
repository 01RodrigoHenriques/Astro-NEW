---
---
<div class="w-full py-16">
  <div class="mx-auto max-w-3xl px-6">
    <div class="text-center mb-12">
      <span class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-gray-400">
        COMO FUNCIONA
      </span>
      <h2 class="text-2xl md:text-3xl lg:text-4xl tracking-tight font-open-sans-custom text-white mt-4">
        Três passos para proteger a sua fábrica
      </h2>
    </div>
    
    <!-- Desktop: Grid com conectores animados -->
    <div class="hidden md:grid md:grid-cols-5 md:items-start md:gap-0 relative">
      <!-- Passo 1 -->
      <div class="flex flex-col items-center text-center col-span-1 relative z-10">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative group">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute inset-0 rounded-2xl border border-white/20 animate-ping opacity-20"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 21V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14l4-4"></path>
            <circle cx="11" cy="11" r="8"></circle>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">01</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Mapear</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed px-2">
          Inventário dinâmico de todos os ativos IT/OT, ligações e dependências críticas da operação.
        </p>
      </div>
      
      <!-- Conector 1-2 com SVG animado -->
      <div class="flex items-center justify-center col-span-1 relative h-16 mt-5">
        <svg class="absolute w-full h-12 overflow-visible" viewBox="0 0 100 20" preserveAspectRatio="none">
          <!-- Linha de fundo -->
          <path d="M 0 10 Q 50 0, 100 10" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <!-- Linha animada -->
          <path d="M 0 10 Q 50 0, 100 10" fill="none" stroke="url(#gradient1)" stroke-width="2" class="animate-dash"/>
          <!-- Partícula -->
          <circle r="3" fill="white" class="animate-particle1">
            <animateMotion dur="2s" repeatCount="indefinite" path="M 0 10 Q 50 0, 100 10"/>
          </circle>
          <defs>
            <linearGradient id="gradient1" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(255,255,255,0.6)"/>
              <stop offset="50%" stop-color="rgba(255,255,255,0.2)"/>
              <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
            </linearGradient>
          </defs>
        </svg>
        <!-- Glow effect -->
        <div class="absolute w-4 h-4 rounded-full bg-white/20 blur-md animate-glow"></div>
      </div>
      
      <!-- Passo 2 -->
      <div class="flex flex-col items-center text-center col-span-1 relative z-10">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative group">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute inset-0 rounded-2xl border border-white/20 animate-ping opacity-20" style="animation-delay: 0.5s;"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">02</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Proteger</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed px-2">
          Deteção de discrepâncias e monitorização contínua do comportamento dos sistemas críticos.
        </p>
      </div>
      
      <!-- Conector 2-3 com SVG animado -->
      <div class="flex items-center justify-center col-span-1 relative h-16 mt-5">
        <svg class="absolute w-full h-12 overflow-visible" viewBox="0 0 100 20" preserveAspectRatio="none">
          <path d="M 0 10 Q 50 20, 100 10" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <path d="M 0 10 Q 50 20, 100 10" fill="none" stroke="url(#gradient2)" stroke-width="2" class="animate-dash" style="animation-delay: 1s;"/>
          <circle r="3" fill="white" class="animate-particle2">
            <animateMotion dur="2s" repeatCount="indefinite" begin="1s" path="M 0 10 Q 50 20, 100 10"/>
          </circle>
          <defs>
            <linearGradient id="gradient2" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(255,255,255,0.6)"/>
              <stop offset="50%" stop-color="rgba(255,255,255,0.2)"/>
              <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="absolute w-4 h-4 rounded-full bg-white/20 blur-md animate-glow" style="animation-delay: 1s;"></div>
      </div>
      
      <!-- Passo 3 -->
      <div class="flex flex-col items-center text-center col-span-1 relative z-10">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative group">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="absolute inset-0 rounded-2xl border border-white/20 animate-ping opacity-20" style="animation-delay: 1s;"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">03</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Documentar</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed px-2">
          Evidência técnica nativa para auditorias, clientes e cumprimento do Decreto-Lei n.º 125/2025.
        </p>
      </div>
    </div>
    
    <!-- Mobile: Stack com setas -->
    <div class="flex md:hidden flex-col items-center gap-4">
      <!-- Passo 1 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative">
          <div class="absolute inset-0 rounded-2xl bg-white/5 animate-pulse"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 21V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14l4-4"></path>
            <circle cx="11" cy="11" r="8"></circle>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">01</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Mapear</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed">
          Inventário dinâmico de todos os ativos IT/OT, ligações e dependências críticas da operação.
        </p>
      </div>
      
      <div class="flex items-center gap-1 my-2">
        <div class="w-8 h-px bg-white/10"></div>
        <svg class="w-4 h-4 text-white/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        <div class="w-8 h-px bg-white/10"></div>
      </div>
      
      <!-- Passo 2 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative">
          <div class="absolute inset-0 rounded-2xl bg-white/5 animate-pulse" style="animation-delay: 0.5s;"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">02</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Proteger</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed">
          Deteção de discrepâncias e monitorização contínua do comportamento dos sistemas críticos.
        </p>
      </div>
      
      <div class="flex items-center gap-1 my-2">
        <div class="w-8 h-px bg-white/10"></div>
        <svg class="w-4 h-4 text-white/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
        <div class="w-8 h-px bg-white/10"></div>
      </div>
      
      <!-- Passo 3 -->
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 relative">
          <div class="absolute inset-0 rounded-2xl bg-white/5 animate-pulse" style="animation-delay: 1s;"></div>
          <svg class="w-8 h-8 text-gray-400 relative z-10" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
          </svg>
        </div>
        <div class="text-xs text-gray-500 font-open-sans-custom mb-2">03</div>
        <h3 class="text-white font-open-sans-custom text-sm font-medium mb-2">Documentar</h3>
        <p class="text-gray-500 text-xs font-open-sans-custom leading-relaxed">
          Evidência técnica nativa para auditorias, clientes e cumprimento do Decreto-Lei n.º 125/2025.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes dash {
    0% { stroke-dasharray: 100; stroke-dashoffset: 100; }
    50% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -100; }
  }
  
  @keyframes glow {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }
  
  .animate-dash {
    stroke-dasharray: 100;
    animation: dash 3s ease-in-out infinite;
  }
  
  .animate-glow {
    animation: glow 2s ease-in-out infinite;
  }
</style>