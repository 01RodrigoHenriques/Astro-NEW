---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProblemSection from '../components/ProblemSection.astro';
import SolutionSection from '../components/SolutionSection.astro';
import SupplyChainSection from '../components/SupplyChainSection.astro';
import MarketParallelSection from '../components/MarketParallelSection.astro';
import QuoteSection from '../components/QuoteSection.astro';
import LeadMagnetForm from '../components/LeadMagnetForm.astro';
import WebGLBackground from '../components/WebGLBackground.astro';
---

<BaseLayout title="Nexus Twin Industrial Suite" description="Nexus Twin — Mais produção, mais controlo e evidência NIS2 sem criar um projeto paralelo de compliance.">
  <main class="relative h-screen overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 -z-10 bg-[#0a1628]">
      <WebGLBackground />
    </div>
    
    <!-- Dark overlay -->
    <div class="fixed inset-0 z-[5] bg-black/30"></div>
    
    <!-- Navigation -->
    <nav class="fixed left-0 right-0 top-0 z-50 px-4 py-4">
      <div class="mx-auto max-w-7xl rounded-xl border border-white/10 bg-black/20 px-6 py-3 backdrop-blur-md">
        <div class="flex items-center justify-between">
<button onclick="scrollToSection('home')" class="cursor-pointer">
            <img src="/favicon.png" alt="Nexus Twin" class="h-12 md:h-14 w-auto mix-blend-screen" />
          </button>
          
          <div class="hidden items-center gap-8 md:flex">
            <button onclick="scrollToSection('problem')" class="text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">O Problema</button>
            <button onclick="scrollToSection('solution')" class="text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Solução</button>
            <button onclick="scrollToSection('supply-chain')" class="text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Supply Chain</button>
            <button onclick="scrollToSection('lead-magnet')" class="text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Guia NIS2</button>
          </div>
          
          <div class="flex items-center gap-3">
            <button onclick="scrollToSection('lead-magnet')" class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-black hover:bg-gray-100 font-open-sans-custom transition-colors">Descarregar Guia</button>
            <button id="mobile-menu-btn" class="cursor-pointer text-white md:hidden" aria-label="Open menu" aria-expanded="false">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6">
                <line x1="4" x2="20" y1="12" y2="12"></line>
                <line x1="4" x2="20" y1="6" y2="6"></line>
                <line x1="4" x2="20" y1="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
        
        <div id="mobile-menu" class="hidden mt-4 flex-col gap-4 border-t border-white/10 pt-4 md:hidden">
          <button onclick="scrollToSection('problem')" class="text-left text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">O Problema</button>
          <button onclick="scrollToSection('solution')" class="text-left text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Solução</button>
          <button onclick="scrollToSection('supply-chain')" class="text-left text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Supply Chain</button>
          <button onclick="scrollToSection('lead-magnet')" class="text-left text-sm font-open-sans-custom text-gray-400 transition-colors hover:text-white">Guia NIS2</button>
        </div>
      </div>
    </nav>
    
    <!-- Horizontal Scroll Container -->
    <div id="scroll-container" class="relative z-10 flex h-screen w-full overflow-x-auto overflow-y-hidden scroll-smooth snap-x snap-mandatory" style="scrollbar-width: none; -ms-overflow-style: none;" tabindex="0" role="region" aria-label="Main content sections">
      
      <!-- SECÇÃO 1: HERO -->
      <section id="home" aria-label="Página inicial" class="flex min-w-[100%] snap-start items-center justify-center px-6 py-20">
        <div class="mx-auto max-w-4xl">
          <div class="text-center">
            <div class="flex justify-center mb-8">
              <img src="/favicon.png" alt="Nexus Twin Industrial Suite" class="h-32 md:h-48 lg:h-64 w-auto max-w-[320px] md:max-w-[480px] lg:max-w-[640px] object-contain" />
            </div>
            <h1 class="mb-6 text-balance text-3xl md:text-4xl lg:text-5xl tracking-tight text-white md:text-5xl lg:text-6xl">
              Mais produção, mais controlo e evidência NIS2 sem criar um projeto paralelo de compliance.
            </h1>
            <p class="mb-8 mx-auto max-w-2xl text-pretty leading-relaxed text-gray-400 font-open-sans-custom text-base md:text-lg">
              A Nexus Twin cria um modelo digital vivo da sua operação industrial. A sua fábrica passa a saber, em tempo quase real, que máquinas, sistemas, fornecedores e acessos externos suportam a produção — e onde estão os pontos que podem parar a operação.
            </p>
            <div class="flex flex-col items-center gap-4">
              <button onclick="scrollToSection('lead-magnet')" class="rounded-xl bg-white px-6 py-3 font-open-sans-custom text-sm font-medium text-black hover:bg-gray-100 transition-colors">
                Descarregar o Guia NIS2 (PDF Gratuito)
              </button>
              <p class="text-xs text-gray-500 font-open-sans-custom">
                Menos ferramentas soltas. Mais visibilidade sobre produção, risco e fornecedores críticos.
              </p>
            </div>
          </div>
        </div>
      </section>
      
      <!-- SECÇÃO 2: O PROBLEMA -->
      <section id="problem" aria-label="O Problema" class="flex min-w-[100%] snap-start items-center justify-center px-4 py-16">
        <div class="mx-auto w-full"><ProblemSection /></div>
      </section>
      
      <!-- SECÇÃO 3: A SOLUÇÃO -->
      <section id="solution" aria-label="Solução" data-section-scrollable class="scroll-fade-bottom relative min-w-[100%] snap-start overflow-y-auto px-4 py-16 hide-scrollbar">
        <div class="relative z-10 mx-auto w-full">
          <SolutionSection />
        </div>
      </section>
      
      <!-- SECÇÃO 4: SUPPLY CHAIN -->
      <section id="supply-chain" aria-label="Supply Chain" class="flex min-w-[100%] snap-start items-center justify-center px-4 py-16">
        <div class="mx-auto w-full"><SupplyChainSection /></div>
      </section>
      
      <!-- SECÇÃO 5: PARALELO DE MERCADO -->
      <section id="market" aria-label="Vantagem Competitiva" data-section-scrollable class="scroll-fade-bottom relative min-w-[100%] snap-start overflow-y-auto px-4 py-16 hide-scrollbar">
        <div class="relative z-10 mx-auto w-full">
          <MarketParallelSection />
        </div>
      </section>
      
      <!-- SECÇÃO 6: SÍNTESE -->
      <section id="quote" aria-label="Síntese" class="flex min-w-[100%] snap-start items-center justify-center px-4 py-16">
        <div class="mx-auto w-full"><QuoteSection /></div>
      </section>
      
      <!-- SECÇÃO 7: LEAD MAGNET -->
      <section id="lead-magnet" aria-label="Guia NIS2" data-section-scrollable class="relative min-w-[100%] snap-start overflow-y-auto px-4 py-16">
        <div class="relative z-10 mx-auto w-full max-w-4xl">
          <LeadMagnetForm />
        </div>
        
        <!-- SECÇÃO 8: RODAPÉ -->
        <footer class="relative z-10 mt-16 pb-8">
          <div class="mx-auto max-w-4xl border-t border-white/10 pt-10">
            <div class="mb-8">
              <p class="text-base md:text-lg text-gray-500 font-open-sans-custom leading-relaxed text-center max-w-2xl mx-auto italic">
                "A conformidade não deve ser uma camada por cima da fábrica. Deve ser uma consequência da forma como a fábrica está desenhada, monitorizada e documentada."
              </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
              <div>
                <h3 class="text-white font-semibold text-sm font-open-sans-custom mb-3">Nexus Twin</h3>
                <p class="text-xs text-gray-500 font-open-sans-custom leading-relaxed">Modelo digital vivo da operação industrial. Mais produção, mais controlo, evidência NIS2 nativa.</p>
              </div>
              <div>
                <h4 class="text-white font-semibold text-xs font-open-sans-custom mb-3 uppercase tracking-wider">Navegação</h4>
                <ul class="space-y-2">
                  <li><button onclick="scrollToSection('problem')" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">O Problema</button></li>
                  <li><button onclick="scrollToSection('solution')" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">Solução</button></li>
                  <li><button onclick="scrollToSection('supply-chain')" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">Supply Chain</button></li>
                  <li><button onclick="scrollToSection('lead-magnet')" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">Guia NIS2</button></li>
                </ul>
              </div>
              <div>
                <h4 class="text-white font-semibold text-xs font-open-sans-custom mb-3 uppercase tracking-wider">Legal</h4>
                <ul class="space-y-2">
                  <li><a href="/politica-privacidade" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">Política de Privacidade</a></li>
                  <li><a href="/termos-uso" class="text-xs text-gray-500 hover:text-white transition-colors font-open-sans-custom">Termos de Uso</a></li>
                </ul>
              </div>
            </div>
            
            <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
              <p class="text-xs text-gray-600 font-open-sans-custom">&copy; 2026 Nexus Twin. Todos os direitos reservados.</p>
              <p class="text-xs text-gray-600 font-open-sans-custom">Desenvolvido por <a href="https://www.linkedin.com/in/rodrigohenriques00/" target="_blank" rel="noopener noreferrer" class="underline hover:text-white transition-colors">Rodrigo Henriques</a></p>
            </div>
          </div>
        </footer>
      </section>
    </div>
  </main>
</BaseLayout>

<script>
  // ===== HORIZONTAL SCROLL =====
  const scrollContainer = document.getElementById('scroll-container') as HTMLElement;
  let currentSection = 0;
  let isScrolling = false;
  
  function scrollToSection(id: string) {
    const el = document.getElementById(id);
    if (el && scrollContainer) {
      const index = Array.from(scrollContainer.children).indexOf(el);
      if (index !== -1) {
        scrollContainer.scrollTo({ left: index * scrollContainer.offsetWidth, behavior: 'smooth' });
        currentSection = index;
      }
    }
  }
  
  (window as any).scrollToSection = scrollToSection;
  
  if (scrollContainer) {
    scrollContainer.addEventListener('wheel', (e: WheelEvent) => {
      const delta = e.deltaY;
      if (Math.abs(delta) < 10) return;
      
      const sections = Array.from(scrollContainer.children);
      const scrollableIndices = sections
        .map((s, i) => (s as HTMLElement).hasAttribute('data-section-scrollable') ? i : -1)
        .filter(i => i !== -1);
      
      if (scrollableIndices.includes(currentSection)) {
        const sectionEl = sections[currentSection] as HTMLElement;
        const isAtTop = sectionEl.scrollTop === 0;
        const isAtBottom = sectionEl.scrollTop + sectionEl.clientHeight >= sectionEl.scrollHeight - 1;
        
        if (delta > 0 && !isAtBottom) return;
        if (delta < 0 && !isAtTop) return;
        
        if (delta < 0 && isAtTop) { e.preventDefault(); scrollToSectionByIndex(currentSection - 1); return; }
        if (delta > 0 && isAtBottom) { e.preventDefault(); if (currentSection < sections.length - 1) scrollToSectionByIndex(currentSection + 1); return; }
      }
      
      e.preventDefault();
      const target = delta > 0 ? Math.min(currentSection + 1, sections.length - 1) : Math.max(currentSection - 1, 0);
      scrollToSectionByIndex(target);
    }, { passive: false });
    
    let touchStartX = 0, touchStartY = 0;
    scrollContainer.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY; }, { passive: true });
    scrollContainer.addEventListener('touchend', (e: TouchEvent) => {
      if (isScrolling) return;
      const deltaX = e.changedTouches[0].clientX - touchStartX;
      const deltaY = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(deltaX) < 50 || Math.abs(deltaX) < Math.abs(deltaY)) return;
      isScrolling = true;
      const sections = Array.from(scrollContainer.children);
      const target = deltaX < 0 ? Math.min(currentSection + 1, sections.length - 1) : Math.max(currentSection - 1, 0);
      scrollToSectionByIndex(target);
      setTimeout(() => { isScrolling = false; }, 600);
    }, { passive: true });
    
    scrollContainer.addEventListener('keydown', (e: KeyboardEvent) => {
      const sections = Array.from(scrollContainer.children);
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); scrollToSectionByIndex(Math.min(currentSection + 1, sections.length - 1)); }
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); scrollToSectionByIndex(Math.max(currentSection - 1, 0)); }
      else if (e.key === 'Home') { e.preventDefault(); scrollToSectionByIndex(0); }
      else if (e.key === 'End') { e.preventDefault(); scrollToSectionByIndex(sections.length - 1); }
    });
    
    scrollContainer.addEventListener('scroll', () => {
      const width = scrollContainer.offsetWidth;
      if (width > 0) currentSection = Math.round(scrollContainer.scrollLeft / width);
    });
    
    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => { scrollContainer.scrollTo({ left: currentSection * scrollContainer.offsetWidth, behavior: 'auto' }); }, 150);
    });
    
    function scrollToSectionByIndex(index: number) {
      const sections = Array.from(scrollContainer.children);
      const clamped = Math.max(0, Math.min(index, sections.length - 1));
      scrollContainer.scrollTo({ left: clamped * scrollContainer.offsetWidth, behavior: 'smooth' });
      currentSection = clamped;
    }
  }

  // ===== MOBILE MENU =====
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', String(!isOpen));
    });
    mobileMenu.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => { mobileMenu.classList.add('hidden'); mobileMenuBtn.setAttribute('aria-expanded', 'false'); });
    });
  }

  // ===== LEAD MAGNET FORM =====
  const leadForm = document.getElementById('lead-form') as HTMLFormElement;
  if (leadForm) {
    leadForm.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const name = (document.getElementById('lead-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('lead-email') as HTMLInputElement).value.trim();
      const company = (document.getElementById('lead-company') as HTMLInputElement).value.trim();
      
      ['name', 'email', 'company'].forEach(f => { document.getElementById(`error-${f}`)?.classList.add('hidden'); });
      
      let valid = true;
      if (!name) { document.getElementById('error-name')!.textContent = 'Nome é obrigatório'; document.getElementById('error-name')!.classList.remove('hidden'); valid = false; }
      if (!email) { document.getElementById('error-email')!.textContent = 'Email é obrigatório'; document.getElementById('error-email')!.classList.remove('hidden'); valid = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { document.getElementById('error-email')!.textContent = 'Email inválido'; document.getElementById('error-email')!.classList.remove('hidden'); valid = false; }
      if (!company) { document.getElementById('error-company')!.textContent = 'Empresa é obrigatória'; document.getElementById('error-company')!.classList.remove('hidden'); valid = false; }
      if (!valid) return;
      
      const submitBtn = leadForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true; submitBtn.textContent = 'A enviar...';
      try { await new Promise(r => setTimeout(r, 1500)); document.getElementById('form-success')!.classList.remove('hidden'); leadForm.reset(); }
      catch { document.getElementById('form-error')!.classList.remove('hidden'); }
      submitBtn.disabled = false; submitBtn.textContent = 'Quero o Guia Prático (PDF Gratuito)';
    });
  }
</script>