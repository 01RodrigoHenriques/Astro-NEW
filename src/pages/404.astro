---
import BaseLayout from '../layouts/BaseLayout.astro';
import WebGLBackground from '../components/WebGLBackground.astro';
---

<BaseLayout title="404 — Nexus Twin">
  <main class="relative min-h-screen flex items-center justify-center">
    <div class="absolute inset-0 -z-10 bg-[#00042e]">
      <WebGLBackground />
    </div>
    <div class="absolute inset-0 z-[5] bg-black/30"></div>
    <div class="relative z-10 text-center px-4">
      <p class="text-8xl font-bold text-white font-open-sans-custom mb-4" style="text-shadow: 0 4px 20px rgba(0,0,0,0.6)">404</p>
      <h1 class="text-2xl font-semibold text-white font-open-sans-custom mb-4">Página não encontrada</h1>
      <p class="text-gray-300 mb-8 font-open-sans-custom">O recurso que procuras não existe ou foi movido.</p>
      <a href="/Astro-NEW/" class="inline-block rounded-md bg-white px-6 py-3 text-sm font-medium text-black hover:bg-gray-100 font-open-sans-custom">Voltar ao início</a>
    </div>
  </main>
</BaseLayout>

