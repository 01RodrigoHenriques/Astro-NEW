---
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoPricing from '../components/BentoPricing.astro';
---

<BaseLayout title="Pricing | BolinaTEC" description="Choose the perfect plan for your needs.">
  <main class="relative min-h-screen bg-[#00042e]">
    <div class="absolute inset-0 -z-10 bg-[#00042e]">
      <canvas id="liquid-canvas" class="liquid-canvas"></canvas>
    </div>
    <div class="fixed inset-0 z-[5] bg-black/50"></div>
    <div aria-hidden="true" class="fixed inset-0 z-[6] size-full bg-[radial-gradient(rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:12px_12px] opacity-30"></div>
    
    <nav class="fixed left-0 right-0 top-0 z-50 px-4 py-4">
      <div class="mx-auto max-w-7xl rounded-2xl border-2 border-white/10 bg-white/5 px-6 py-4 backdrop-blur-sm">
        <div class="flex items-center justify-between">
          <a href="/" class="text-white font-bold text-lg">BolinaTEC</a>
          <a href="/" class="rounded-md bg-white px-4 py-2 text-sm font-medium text-black hover:bg-gray-100">Home</a>
        </div>
      </div>
    </nav>
    
    <section class="relative z-10 flex min-h-screen items-center px-4 py-20">
      <div class="mx-auto w-full max-w-5xl">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <h2 class="text-4xl font-extrabold tracking-tight lg:text-6xl text-white [text-shadow:_0_4px_20px_rgb(0_0_0_/_60%)] font-open-sans-custom">Plans and Pricing</h2>
          <p class="text-gray-300 mt-4 text-sm md:text-base font-open-sans-custom [text-shadow:_0_2px_10px_rgb(0_0_0_/_50%)]">Choose the perfect plan for your needs.</p>
        </div>
        <BentoPricing />
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
(function(){
  var c=document.getElementById('liquid-canvas');if(!c)return;var gl=c.getContext('webgl');if(!gl)return;
  var vs=gl.createShader(gl.VERTEX_SHADER);gl.shaderSource(vs,'attribute vec2 p;void main(){gl_Position=vec4(p,0,1);}');gl.compileShader(vs);
  var fs=gl.createShader(gl.FRAGMENT_SHADER);gl.shaderSource(fs,'precision mediump float;uniform float t;uniform vec2 r;vec3 mod289(vec3 x){return x-floor(x/289.)*289.;}vec2 mod289(vec2 x){return x-floor(x/289.)*289.;}vec3 perm(vec3 x){return mod289(((x*34.)+1.)*x);}float snoise(vec2 v){const vec4 C=vec4(.21132,.36603,-.57735,.02439);vec2 i=floor(v+dot(v,C.yy));vec2 x0=v-i+dot(i,C.xx);vec2 i1=(x0.x>x0.y)?vec2(1,0):vec2(0,1);vec4 x12=x0.xyxy+C.xxzz;x12.xy-=i1;i=mod289(i);vec3 p=perm(perm(i.y+vec3(0,i1.y,1))+i.x+vec3(0,i1.x,1));vec3 m=max(.5-vec3(dot(x0,x0),dot(x12.xy,x12.xy),dot(x12.zw,x12.zw)),0.);m=m*m;m=m*m;vec3 x=2.*fract(p*C.www)-1.;vec3 h=abs(x)-.5;vec3 ox=floor(x+.5);vec3 a0=x-ox;m*=1.79284-.85373*(a0*a0+h*h);vec3 g;g.x=a0.x*x0.x+h.x*x0.y;g.yz=a0.yz*x12.xz+h.yz*x12.yw;return 130.*dot(m,g);}void main(){vec2 uv=gl_FragCoord.xy/r;float T=t*.4;float n1=snoise(uv*3.+vec2(T*.8,T*.4));float n2=snoise(uv*5.+vec2(-T*.6,T*.9));float n3=snoise(uv*2.+vec2(T*.3,-T*.5));float v=n1*.5+n2*.3+n3*.2;vec3 c0=vec3(0,.016,.18);vec3 c1=vec3(.357,.302,.78);vec3 c2=vec3(.55,.45,.95);float s=(v+1.)*.5;vec3 c=c0;c=mix(c,c1,smoothstep(.2,.6,s));c=mix(c,c2,smoothstep(.5,.9,s)*.6);float h=snoise(uv*10.+vec2(T*1.5,T));c+=vec3(.15,.1,.3)*pow(max(h,0.),4.)*.8;float d=1.-length((uv-.5)*1.3);c*=smoothstep(0.,.6,d);gl_FragColor=vec4(c,1);}');gl.compileShader(fs);
  var pg=gl.createProgram();gl.attachShader(pg,vs);gl.attachShader(pg,fs);gl.linkProgram(pg);gl.useProgram(pg);
  var b=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,b);gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),gl.STATIC_DRAW);
  var pos=gl.getAttribLocation(pg,'p');gl.enableVertexAttribArray(pos);gl.vertexAttribPointer(pos,2,gl.FLOAT,false,0,0);
  var tL=gl.getUniformLocation(pg,'t');var rL=gl.getUniformLocation(pg,'r');
  function resize(){c.width=window.innerWidth;c.height=window.innerHeight;gl.viewport(0,0,c.width,c.height);}
  var t0=performance.now();function render(){gl.uniform1f(tL,(performance.now()-t0)/1000);gl.uniform2f(rL,c.width,c.height);gl.drawArrays(gl.TRIANGLE_STRIP,0,4);requestAnimationFrame(render);}
  resize();render();window.addEventListener('resize',resize);
})();
</script>
